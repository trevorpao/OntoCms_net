@model OntoCms.Modules.Option.HomePageViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="@Model.HtmlLang">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.DocumentTitle</title>
    <style>
        :root {
            color-scheme: light;
            font-family: Georgia, "Times New Roman", serif;
        }

        body {
            margin: 0;
            min-height: 100vh;
            display: grid;
            place-items: center;
            background: linear-gradient(135deg, #f6f1e8 0%, #efe7d9 100%);
            color: #1f1a16;
        }

        main {
            width: min(42rem, calc(100vw - 3rem));
            padding: 3rem;
            border: 1px solid rgba(31, 26, 22, 0.12);
            background: rgba(255, 252, 247, 0.84);
            box-shadow: 0 24px 60px rgba(58, 44, 31, 0.12);
        }

        .eyebrow {
            margin: 0 0 1rem;
            font-size: 0.95rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: #7a6757;
        }

        .lang-switch {
            display: flex;
            gap: 0.75rem;
            margin: 0 0 2rem;
        }

        .lang-switch a {
            color: #7a6757;
            text-decoration: none;
            border-bottom: 1px solid transparent;
            padding-bottom: 0.2rem;
        }

        .lang-switch a.active {
            color: #1f1a16;
            border-color: currentColor;
        }

        h1 {
            margin: 0 0 1.5rem;
            font-size: clamp(2.5rem, 6vw, 4.5rem);
            font-weight: 500;
            line-height: 0.95;
        }

        article {
            font-size: 1.05rem;
            line-height: 1.75;
            color: #34291f;
        }

        article p {
            margin: 0 0 1rem;
        }

        .empty {
            color: #7a6757;
            font-style: italic;
        }
    </style>
</head>
<body>
    <main>
        <p class="eyebrow">@Model.SiteTitle</p>
        <nav class="lang-switch" aria-label="Language switch">
            <a class="@(Model.CurrentLang == "tw" ? "active" : null)" href="@Model.ChineseAboutPath">中文</a>
            <a class="@(Model.CurrentLang == "en" ? "active" : null)" href="@Model.EnglishAboutPath">English</a>
        </nav>
        <h1>@Model.PageTitle</h1>
        <article>
            @if (string.IsNullOrWhiteSpace(Model.Content))
            {
                <p class="empty">Content is not available yet.</p>
            }
            else
            {
                @Html.Raw(Model.Content)
            }
        </article>
    </main>
</body>
</html>